{
  "manifest_version": 3,
  "name": "Sprintbrain",
  "version": "2.10.1",
  "description": "Type ::quoteEN in any text field — configurable dual triggers for snippets and prompts.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://eyowustlbqujaimaxggt.supabase.co/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "overlay.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sprintbrain ⚡"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}