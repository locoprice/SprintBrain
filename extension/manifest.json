{
  "manifest_version": 3,
  "name": "Sprintbrain",
  "version": "2.20.5",
  "description": "Type ::quoteEN in any text field — configurable dual triggers for snippets and prompts.",
  "key": "",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://eyowustlbqujaimaxggt.supabase.co/*",
    "https://api.notion.com/*"
  ],
  "externally_connectable": {
    "matches": ["https://sprintbrain.netlify.app/*"]
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "tokens/colors_and_type.css",
        "overlay/overlay.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SprintBrain"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
