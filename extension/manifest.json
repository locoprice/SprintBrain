{
  "manifest_version": 3,
  "name": "SprintBrain",
  "version": "2.103.0",
  "description": "Expand reusable text snippets in any field using custom shortcuts. Organize into folders and sync your library with Notion.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://eyowustlbqujaimaxggt.supabase.co/*",
    "https://api.notion.com/*"
  ],
  "externally_connectable": {
    "matches": ["https://app.sprintbrain.com/*"]
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "formula-engine.js",
        "content/content.js"
      ],
      "css": [
        "overlay/overlay.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SprintBrain"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
